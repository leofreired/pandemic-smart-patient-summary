# App
APP_PORT=8080
SAMPLE_MODE=true
LOOKBACK_DAYS=180

# InterSystems FHIR API
FHIR_BASE_URL=http://iris-health:52773/csp/healthshare/fhirserver/fhir/r4
FHIR_BEARER_TOKEN=
FHIR_USERNAME=
FHIR_PASSWORD=
FHIR_OAUTH_TOKEN_URL=
FHIR_OAUTH_CLIENT_ID=
FHIR_OAUTH_CLIENT_SECRET=
FHIR_OAUTH_SCOPE=
FHIR_VERIFY_TLS=true

# InterSystems FHIR SQL Builder endpoint (optional)
FHIR_SQL_ENDPOINT=http://iris-health:52773/csp/fhirsql/api/query
FHIR_SQL_USERNAME=
FHIR_SQL_PASSWORD=

# InterSystems AI Hub (OpenAI-compatible style endpoint)
AI_HUB_BASE_URL=
AI_HUB_API_KEY=
AI_HUB_MODEL=gpt-4o-mini
AI_HUB_TIMEOUT_SECONDS=30
